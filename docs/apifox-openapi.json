{
  "openapi": "3.0.3",
  "info": {
    "title": "活动运营数据分析 Agent - 后端接口文档",
    "description": "可直接导入 Apifox 的 OpenAPI 3.0 文档，覆盖当前 Spring Boot 后端已实现接口。",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "健康检查"
    },
    {
      "name": "认证"
    },
    {
      "name": "活动管理"
    },
    {
      "name": "活动参与"
    },
    {
      "name": "奖励发放"
    },
    {
      "name": "活动统计"
    },
    {
      "name": "Agent 查询"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "健康检查"
        ],
        "summary": "服务首页",
        "operationId": "index",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMapObject"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "健康检查"
        ],
        "summary": "健康检查",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultMapObject"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "认证"
        ],
        "summary": "用户登录",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "username": "admin",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultLoginResponse"
                }
              }
            }
          }
        }
      }
    },
    "/activity/create": {
      "post": {
        "tags": [
          "活动管理"
        ],
        "summary": "创建活动",
        "operationId": "createActivity",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActivityCreateRequest"
              },
              "example": {
                "activityName": "618加码活动",
                "activityType": "NEW_USER",
                "startTime": "2026-06-01T00:00:00",
                "endTime": "2026-06-30T23:59:59",
                "status": 1,
                "ruleDesc": "新用户参与后发放优惠券"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultActivity"
                }
              }
            }
          }
        }
      }
    },
    "/activity/list": {
      "get": {
        "tags": [
          "活动管理"
        ],
        "summary": "活动列表",
        "operationId": "listActivities",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultActivityList"
                }
              }
            }
          }
        }
      }
    },
    "/activity/{id}": {
      "get": {
        "tags": [
          "活动管理"
        ],
        "summary": "活动详情",
        "operationId": "getActivityDetail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultActivity"
                }
              }
            }
          }
        }
      }
    },
    "/activity/update": {
      "put": {
        "tags": [
          "活动管理"
        ],
        "summary": "更新活动",
        "operationId": "updateActivity",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActivityUpdateRequest"
              },
              "example": {
                "id": 1,
                "ruleDesc": "新用户参与后发放优惠券和积分"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultActivity"
                }
              }
            }
          }
        }
      }
    },
    "/activity/participate": {
      "post": {
        "tags": [
          "活动参与"
        ],
        "summary": "参与活动",
        "operationId": "participateActivity",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ParticipateRequest"
              },
              "example": {
                "activityId": 1,
                "userId": 90001,
                "channel": "APP"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultActivityUserRecord"
                }
              }
            }
          }
        }
      }
    },
    "/reward/send": {
      "post": {
        "tags": [
          "奖励发放"
        ],
        "summary": "发放奖励",
        "operationId": "sendReward",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RewardSendRequest"
              },
              "example": {
                "activityId": 1,
                "userId": 90001,
                "rewardType": "COUPON",
                "rewardAmount": 10
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultRewardRecord"
                }
              }
            }
          }
        }
      }
    },
    "/statistics/activity": {
      "get": {
        "tags": [
          "活动统计"
        ],
        "summary": "查询活动统计",
        "operationId": "queryActivityStatistics",
        "parameters": [
          {
            "name": "activityId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultActivityStatisticsList"
                }
              }
            }
          }
        }
      }
    },
    "/agent/query": {
      "post": {
        "tags": [
          "Agent 查询"
        ],
        "summary": "自然语言查询",
        "operationId": "queryAgent",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentQueryRequest"
              },
              "examples": {
                "snake_case": {
                  "value": {
                    "question": "统计最近7天各活动的参与人数",
                    "user_id": 1
                  }
                },
                "camelCase": {
                  "value": {
                    "question": "统计最近7天各活动的参与人数",
                    "userId": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ResultAgentQueryResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ResultMapObject": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "ResultLoginResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/LoginResponse"
          }
        }
      },
      "ResultActivity": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/Activity"
          }
        }
      },
      "ResultActivityList": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Activity"
            }
          }
        }
      },
      "ResultActivityUserRecord": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/ActivityUserRecord"
          }
        }
      },
      "ResultRewardRecord": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/RewardRecord"
          }
        }
      },
      "ResultActivityStatisticsList": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ActivityStatistics"
            }
          }
        }
      },
      "ResultAgentQueryResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 1
          },
          "message": {
            "type": "string",
            "example": "success"
          },
          "data": {
            "$ref": "#/components/schemas/AgentQueryResponse"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "username",
          "password"
        ],
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "e7d2f9df0ef54b3ca0e2f6df0d8f3a1b"
          }
        }
      },
      "ActivityCreateRequest": {
        "type": "object",
        "required": [
          "activityName",
          "activityType",
          "startTime",
          "endTime",
          "status"
        ],
        "properties": {
          "activityName": {
            "type": "string"
          },
          "activityType": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer",
            "description": "0未开始 1进行中 2已结束"
          },
          "ruleDesc": {
            "type": "string"
          }
        }
      },
      "ActivityUpdateRequest": {
        "type": "object",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "activityName": {
            "type": "string"
          },
          "activityType": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer"
          },
          "ruleDesc": {
            "type": "string"
          }
        }
      },
      "ParticipateRequest": {
        "type": "object",
        "required": [
          "activityId",
          "userId",
          "channel"
        ],
        "properties": {
          "activityId": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "channel": {
            "type": "string",
            "example": "APP"
          }
        }
      },
      "RewardSendRequest": {
        "type": "object",
        "required": [
          "activityId",
          "userId",
          "rewardType",
          "rewardAmount"
        ],
        "properties": {
          "activityId": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "rewardType": {
            "type": "string",
            "example": "COUPON"
          },
          "rewardAmount": {
            "type": "number",
            "format": "double",
            "example": 10
          }
        }
      },
      "AgentQueryRequest": {
        "type": "object",
        "required": [
          "question",
          "user_id"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "user_id": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64",
            "description": "兼容字段，后端同样支持"
          }
        }
      },
      "Activity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "activityName": {
            "type": "string"
          },
          "activityType": {
            "type": "string"
          },
          "startTime": {
            "type": "string",
            "format": "date-time"
          },
          "endTime": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "integer"
          },
          "ruleDesc": {
            "type": "string"
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ActivityUserRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "activityId": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "channel": {
            "type": "string"
          },
          "participateStatus": {
            "type": "integer"
          },
          "participateTime": {
            "type": "string",
            "format": "date-time"
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RewardRecord": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "activityId": {
            "type": "integer",
            "format": "int64"
          },
          "userId": {
            "type": "integer",
            "format": "int64"
          },
          "rewardType": {
            "type": "string"
          },
          "rewardAmount": {
            "type": "number",
            "format": "double"
          },
          "sendStatus": {
            "type": "integer",
            "description": "0初始化 1成功 2失败"
          },
          "failReason": {
            "type": "string"
          },
          "sendTime": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ActivityStatistics": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "activityId": {
            "type": "integer",
            "format": "int64"
          },
          "statDate": {
            "type": "string",
            "format": "date"
          },
          "participantCount": {
            "type": "integer"
          },
          "rewardCount": {
            "type": "integer"
          },
          "rewardSuccessCount": {
            "type": "integer"
          },
          "conversionRate": {
            "type": "number",
            "format": "double"
          },
          "retentionRate": {
            "type": "number",
            "format": "double"
          },
          "createTime": {
            "type": "string",
            "format": "date-time"
          },
          "updateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AgentQueryResponse": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "generatedSql": {
            "type": "string"
          },
          "queryResult": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "answer": {
            "type": "string"
          },
          "success": {
            "type": "boolean"
          },
          "errorMessage": {
            "type": "string",
            "nullable": true
          }
        }
      }
    }
  }
}
